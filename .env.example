# Workspace the agents read/edit (shared filesystem). Absolute path recommended.
WORKSPACE_DIR=/home/dax/pipeline-moe

# HTTP port for the Express API.
PORT=5300

# Model in "provider/id" form. When unset, the backend prefers the `local`
# provider from ~/.pi/agent/models.json (llama-server :5000). Set this explicitly
# to be safe and avoid ever falling back to a cloud model.
PIPELINE_MODEL=local/Qwopus3.6-27B-v2-MTP-Q5_K_M.gguf

# Thinking level for sub-agents: off | minimal | low | medium | high | xhigh
PIPELINE_THINKING=medium
