{
  "name": "pipeline-moe",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pipeline-MoE — multi-agent chat room orchestrating N stateful pi AgentSession instances over a shared workspace.",
  "scripts": {
    "predev": "bash scripts/predev.sh",
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "tsx watch src/server.ts",
    "dev:frontend": "npm -C web run dev",
    "start": "tsx src/server.ts",
    "start:full": "bash start.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.79.4",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "typebox": "^1.2.16",
    "youtube-transcript-plus": "^2.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "concurrently": "^10.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
