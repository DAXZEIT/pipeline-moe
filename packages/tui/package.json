{
  "name": "@pipeline-moe/tui",
  "version": "0.1.40",
  "license": "MIT",
  "type": "module",
  "description": "Terminal client for pipeline-moe — a multi-room, multi-agent orchestration TUI built on @pipeline-moe/client-core and Ink.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DAXZEIT/pipeline-moe.git",
    "directory": "packages/tui"
  },
  "keywords": [
    "pipeline-moe",
    "multi-agent",
    "tui",
    "terminal",
    "ink",
    "orchestration"
  ],
  "engines": {
    "node": ">=20.12"
  },
  "bin": {
    "pmoe": "./bin/pmoe.mjs"
  },
  "files": [
    "bin",
    "src",
    "tsconfig.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "tsx src/cli.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pipeline-moe/client-core": "^0.1.14",
    "chalk": "^5.6.2",
    "eventsource": "^3.0.2",
    "ink": "^5.1.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "react": "^18.3.1",
    "string-width": "^7.2.0",
    "tsx": "^4.19.0",
    "wrap-ansi": "^9.0.2"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/react": "^18.3.12",
    "typescript": "^5.6.0"
  }
}
